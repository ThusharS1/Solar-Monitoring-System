<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@color/bg_card"
    android:layout_marginBottom="10dp">

    <!-- Blue left border -->
    <View android:layout_width="4dp" android:layout_height="match_parent"
        android:background="@color/blue_light"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="14dp">

        <TextView android:id="@+id/tv_tip_title"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/blue_light" android:textSize="14sp"
            android:textStyle="bold" android:layout_marginBottom="6dp"/>

        <TextView android:id="@+id/tv_tip_body"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/text_muted" android:textSize="13sp"
            android:lineSpacingMultiplier="1.4"/>

        <TextView android:id="@+id/tv_tip_saving"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/green_light" android:textSize="12sp"
            android:textStyle="bold" android:layout_marginTop="8dp"
            android:visibility="gone"/>
    </LinearLayout>
</LinearLayout>
