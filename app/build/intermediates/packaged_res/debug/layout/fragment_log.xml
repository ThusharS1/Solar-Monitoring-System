<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- Input Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="18dp"
            android:layout_marginBottom="14dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="18dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="LOG TODAY'S GENERATION"
                    android:textColor="@color/text_muted" android:textSize="11sp"
                    android:letterSpacing="0.1" android:layout_marginBottom="16dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="☀️  Solar Generated (kWh) *"
                    android:textColor="@color/text_muted" android:textSize="12sp" android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:boxStrokeColor="@color/green_dark"
                    app:hintTextColor="@color/text_muted">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_generated"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="e.g.  8.5"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_muted"/>
                </com.google.android.material.textfield.TextInputLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🏠  Previous Meter Reading"
                    android:textColor="@color/text_muted" android:textSize="12sp" android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:boxStrokeColor="@color/green_dark">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_prev_meter"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="numberDecimal" android:hint="e.g.  1240"
                        android:textColor="@color/text_primary" android:textColorHint="@color/text_muted"/>
                </com.google.android.material.textfield.TextInputLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🏠  Current Meter Reading *"
                    android:textColor="@color/text_muted" android:textSize="12sp" android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:boxStrokeColor="@color/green_dark">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_curr_meter"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="numberDecimal" android:hint="e.g.  1246"
                        android:textColor="@color/text_primary" android:textColorHint="@color/text_muted"/>
                </com.google.android.material.textfield.TextInputLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="💰  Per Unit Rate (₹/kWh)"
                    android:textColor="@color/text_muted" android:textSize="12sp" android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"
                    app:boxStrokeColor="@color/green_dark">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_rate"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="numberDecimal" android:hint="e.g.  8"
                        android:text="8"
                        android:textColor="@color/text_primary" android:textColorHint="@color/text_muted"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:text="💾  SAVE ENTRY"
                    android:textSize="16sp" android:letterSpacing="0.05"
                    app:backgroundTint="@color/green_dark"
                    app:cornerRadius="10dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- History Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="18dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="18dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ENERGY LOG HISTORY"
                    android:textColor="@color/text_muted" android:textSize="11sp"
                    android:letterSpacing="0.1" android:layout_marginBottom="12dp"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_history"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
