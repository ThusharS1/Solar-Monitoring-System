<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- Total Savings Banner -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardBackgroundColor="#1a2f00" app:cardCornerRadius="18dp"
            android:layout_marginBottom="14dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="30-DAY SAVINGS" android:textColor="@color/green_light"
                    android:textSize="12sp" android:letterSpacing="0.1"/>
                <TextView android:id="@+id/tv_total_savings"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="₹0" android:textColor="@color/yellow"
                    android:textSize="48sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="saved on electricity bills" android:textColor="@color/green_light"
                    android:textSize="13sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Bar Chart -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="18dp"
            android:layout_marginBottom="14dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="18dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="DAILY GENERATION (kWh)"
                    android:textColor="@color/text_muted" android:textSize="11sp"
                    android:letterSpacing="0.1" android:layout_marginBottom="12dp"/>
                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/bar_chart"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Summary Table -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="18dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="18dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="30-DAY SUMMARY"
                    android:textColor="@color/text_muted" android:textSize="11sp"
                    android:letterSpacing="0.1" android:layout_marginBottom="12dp"/>

                <!-- Row: Total Generated -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Total Generated"
                        android:textColor="@color/text_muted" android:textSize="14sp"/>
                    <TextView android:id="@+id/tv_total_generated"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/yellow"
                        android:textSize="14sp" android:textStyle="bold"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border"/>

                <!-- Row: Entry Count -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Days Logged"
                        android:textColor="@color/text_muted" android:textSize="14sp"/>
                    <TextView android:id="@+id/tv_days_logged"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/text_primary"
                        android:textSize="14sp" android:textStyle="bold"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border"/>

                <!-- Row: Per unit rate -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Per Unit Rate"
                        android:textColor="@color/text_muted" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="₹8.00 / kWh"
                        android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border"/>

                <!-- Row: Net Savings -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="50dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Net Savings"
                        android:textColor="@color/green_light" android:textSize="15sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tv_net_savings"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/green_light"
                        android:textSize="20sp" android:textStyle="bold"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
